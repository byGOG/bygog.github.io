{
  "permissions": {
    "allow": [
      "Bash(Start-Process \"http://localhost:3000\")",
      "Bash(cmd.exe /c start http://localhost:3000)",
      "Bash(where node:*)",
      "Bash(where npx:*)",
      "Bash(where pwsh:*)",
      "Bash(where powershell:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/)"
    ]
  }
}
